            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Daiane\",\n  \"email\": \"daiane@email.com\"\n}"
            },
            "url": "{{app}}/api/usuarios"
          }
        },
        {
          "name": "Buscar Usuario por ID",
