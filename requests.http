###
# MICROSERVICO - PONTO DE COLETA (FLUXO COMPLETO)
POST {{msPontoColeta}}/api/pontos-coleta/requests
Content-Type: application/json

{
  "opensPc": true,
  "nameUser": "Daiane Camargo",
  "linkPhoto": "https://images.example.com/ponto-centro.jpg",
  "cpfUser": "11144477735",
  "cpnjPoint": "11222333000181",
  "emailUser": "daiane@email.com",
  "celUser": "11988887777",
  "namePoint": "Ponto Centro",
  "hourInit": "08:00",
  "hour": "18:00",
  "address": {
    "street": "Rua das Flores",
    "number": "100",
    "complement": "Sala 2",
    "district": "Centro",
    "city": "Sao Paulo",
    "postCode": "01001000"
  }
}

###
GET {{msPontoColeta}}/api/pontos-coleta/requests

###
GET {{msPontoColeta}}/api/pontos-coleta/requests?status=PENDENTE

###
GET {{msPontoColeta}}/api/pontos-coleta/requests/1

###
PATCH {{msPontoColeta}}/api/pontos-coleta/requests/1
Content-Type: application/json

{
  "hourInit": "09:00",
  "hour": "19:00",
  "address": {
    "street": "Rua das Flores",
    "number": "120",
    "complement": "Sala 2",
    "district": "Centro",
    "city": "Sao Paulo",
    "postCode": "01001000"
  }
}

###
PATCH {{msPontoColeta}}/api/pontos-coleta/requests/1/review
Content-Type: application/json

{
  "decision": "APPROVE",
  "reason": "Documentacao validada"
}

###
PATCH {{msPontoColeta}}/api/pontos-coleta/requests/2/review
Content-Type: application/json

{
  "decision": "REJECT",
  "reason": "Endereco inconsistente"
}

###
GET {{msPontoColeta}}/api/pontos-coleta/approved

