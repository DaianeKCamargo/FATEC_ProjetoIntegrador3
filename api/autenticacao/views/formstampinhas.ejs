<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Novo Relatório de Tampinhas</title>
</head>
<body>
    <h1>Criar Relatório de Tampinhas</h1>

    <form action="/tampinhas" method="POST">
        <label>Data:</label>
        <input type="date" name="data" required>

        <label>Quantidade em Kg:</label>
        <input type="number" step="0.01" name="quantidadeKg" min="0" required>

        <label>Quantidade em gramas:</label>
        <input type="number" name="peso_gramas" min="0" required>

        <label>Quantidade de tampinhas:</label>
        <input type="number" name="quantidade_tampinhas" min="0" required>

        <button type="submit">Salvar</button>
    </form>

    <div style="margin-top: 16px;">
        <a href="/tampinhas">Voltar</a>
    </div>
</body>
</html>