# Database connection string for PostgreSQL
# Local: postgresql://user:password@localhost:5432/tampets_db
# Vercel: Get from your PostgreSQL provider (Railway, Neon, Render, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/tampets_db"

# Application ports
PORT=5500
PONTO_COLETA_PORT=5501
AUTENTICACAO_PORT=5502
RELATORIO_ANIMAIS_PORT=5503
RELATORIO_TAMPINHAS_PORT=5504

# Environment
NODE_ENV=development
