    {
      "name": "App Principal - Pontos de Coleta",
      "item": [
        {
          "name": "Listar Pontos de Coleta",
          "request": {
            "method": "GET",
            "url": "{{app}}/api/collection-point"
          }
        },
        {
          "name": "Criar Ponto de Coleta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nameUser\": \"Daiane Camargo\",\n  \"cpfUser\": \"11144477735\",\n  \"celUser\": \"11988887777\",\n  \"emailUser\": \"daiane@example.com\",\n  \"linkPhoto\": \"https://example.com/photo.jpg\",\n  \"namePoint\": \"Ponto Centro\",\n  \"cnpjPoint\": \"11222333000181\",\n  \"opensDay\": \"Segunda a Sexta\",\n  \"hourInit\": \"08:00\",\n  \"hourFinal\": \"18:00\",\n  \"address\": {\n    \"street\": \"Rua das Flores\",\n    \"number\": \"100\",\n    \"district\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"postCode\": \"01001000\"\n  }\n}"
            },
            "url": "{{app}}/api/collection-point"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.idPc) {",
                  "    pm.collectionVariables.set(\"pontoColetaId\", String(jsonData.idPc));",
                  "    pm.collectionVariables.set(\"solicitacaoId\", String(jsonData.idPc));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar Ponto de Coleta por ID",
          "request": {
            "method": "GET",
            "url": "{{app}}/api/collection-point/{{pontoColetaId}}"
          }
        },
        {
          "name": "Listar Pontos Aprovados",
          "request": {
            "method": "GET",
            "url": "{{app}}/api/collection-point/approved"
          }
        },
        {
          "name": "Atualizar Status do Ponto de Coleta",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APROVADO\",\n  \"reason\": \"Documentacao validada\"\n}"
            },
            "url": "{{app}}/api/collection-point/{{pontoColetaId}}/status"
          }
        },
        {
          "name": "Atualizar Ponto de Coleta",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"namePoint\": \"Ponto Centro Atualizado\",\n  \"hourInit\": \"09:00\",\n  \"address\": {\n    \"number\": \"120\"\n  }\n}"
            },
            "url": "{{app}}/api/collection-point/{{pontoColetaId}}"
          }
        },
        {
          "name": "Remover Ponto de Coleta",
          "request": {
            "method": "DELETE",
            "url": "{{app}}/api/collection-point/{{pontoColetaId}}"
          }
        }
      ]
    },
