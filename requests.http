###
# APP PRINCIPAL - USUARIOS
GET {{app}}/api/usuarios

###
POST {{app}}/api/usuarios
Content-Type: application/json

{
  "nome": "Daiane",
  "email": "daiane@email.com"
}

###
GET {{app}}/api/usuarios/1

###
PUT {{app}}/api/usuarios/1
Content-Type: application/json

{
  "nome": "Daiane Atualizada",
  "email": "daiane.atualizada@email.com"
}

###
DELETE {{app}}/api/usuarios/1

