<!doctype html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Login - Autenticacao</title>
</head>

<body>
    <h1>Login</h1>
    <% if (message) { %>
        <p>
            <%= message %>
        </p>
        <% } %>
            <form method="post" action="/login">
                <label>Usuario: <input type="text" name="usuario" /></label><br />
                <label>Senha: <input type="password" name="senha" /></label><br />
                <button type="submit">Entrar</button>
            </form>
            <p><a href="/credenciais">Ver credenciais</a> | <a href="/credenciais/novo">Criar credencial</a></p>
</body>

</html>