<!DOCTYPE html>
<html>
<head>
    <title>Relatórios de Animais</title>
</head>
<body>
    <h1>Relatórios de Animais</h1>

    <a href="/relatorios/novo">Novo Relatório</a>

    <ul>
        <% relatorios.forEach(r => { %>
            <li>
                <strong>Data:</strong> <%= r.data %> |
                <strong>Animal:</strong> <%= r.tipoAnimal %> |
                <strong>Qtd:</strong> <%= r.quantidade %>
                <br>

                <a href="/relatorios/<%= r.id %>">Ver</a> |
                <a href="/relatorios/<%= r.id %>/editar">Editar</a>

                <form action="/relatorios/<%= r.id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit">Excluir</button>
                </form>
            </li>
        <% }) %>
    </ul>
</body>
</html>