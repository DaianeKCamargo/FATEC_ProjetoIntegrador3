<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Detalhe do Ponto</title>
</head>

<body>
    <% if (typeof error !=='undefined' && error) { %>
        <p>
            <%= error %>
        </p>
        <% } else { %>
            <% const item=ponto || solicitacao; %>
                <h1>Detalhe do Ponto de Coleta</h1>
                <p><strong>ID:</strong>
                    <%= item.idPc || item.id || '' %>
                </p>
                <p><strong>Nome do ponto:</strong>
                    <%= item.namePoint || item.nome || '' %>
                </p>
                <p><strong>Status:</strong>
                    <%= item.status || 'PENDENTE' %>
                </p>
                <p><strong>Responsável:</strong>
                    <%= item.nameUser || item.nome || '' %>
                </p>
                <p><strong>Cidade:</strong>
                    <%= item.address ? item.address.city : '' %>
                </p>
                <% } %>

                    <a href="/pontos/solicitacao">Voltar</a>
</body>

</html>