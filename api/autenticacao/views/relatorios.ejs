<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Relatórios de Animais</title>
</head>
<body>
    <h1>Relatórios de Animais</h1>

    <a href="/relatorios-animais/novo">Novo Relatório</a>

    <ul>
        <% relatorios.forEach(r => { %>
            <li>
                <strong>Data:</strong> <%= r.data %> |
                <strong>Animal:</strong> <%= r.tipoAnimal %> |
                <strong>Qtd:</strong> <%= r.quantidade %>
                <br>

                <a href="/relatorios-animais/<%= r.id %>">Ver</a>
            </li>
        <% }) %>
    </ul>

    <div style="margin-top: 16px;">
        <a href="/relatorio">Voltar ao menu de relatórios</a>
    </div>
</body>
</html>