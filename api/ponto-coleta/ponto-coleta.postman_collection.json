            "value": "1"
        },
        {
            "key": "requestIdReject",
            "value": "2"
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "Healthcheck",
                    "request": {
                        "method": "GET",
                        "url": "{{msPontoColeta}}/health"
                    }
                }
            ]
        },
        {
            "name": "Solicitacoes",
            "item": [
                {
                    "name": "Criar Solicitacao",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"opensPc\": true,\n  \"nameUser\": \"Daiane Camargo\",\n  \"linkPhoto\": \"https://images.example.com/ponto-centro.jpg\",\n  \"cpfUser\": \"11144477735\",\n  \"cpnjPoint\": \"11222333000181\",\n  \"emailUser\": \"daiane@email.com\",\n  \"celUser\": \"11988887777\",\n  \"namePoint\": \"Ponto Centro\",\n  \"hourInit\": \"08:00\",\n  \"hour\": \"18:00\",\n  \"address\": {\n    \"street\": \"Rua das Flores\",\n    \"number\": \"100\",\n    \"complement\": \"Sala 2\",\n    \"district\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"postCode\": \"01001000\"\n  }\n}"
                        },
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests"
                    }
                },
                {
                    "name": "Listar Solicitacoes",
                    "request": {
                        "method": "GET",
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests"
                    }
                },
                {
                    "name": "Listar Solicitacoes por Status",
                    "request": {
                        "method": "GET",
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests?status=PENDENTE"
                    }
                },
                {
                    "name": "Buscar Solicitacao por ID",
                    "request": {
                        "method": "GET",
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests/{{requestId}}"
                    }
                },
                {
                    "name": "Atualizar Solicitacao",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"hourInit\": \"09:00\",\n  \"hour\": \"19:00\",\n  \"address\": {\n    \"street\": \"Rua das Flores\",\n    \"number\": \"120\",\n    \"complement\": \"Sala 2\",\n    \"district\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"postCode\": \"01001000\"\n  }\n}"
                        },
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests/{{requestId}}"
                    }
                }
            ]
        },
        {
            "name": "Revisao",
            "item": [
                {
                    "name": "Aprovar Solicitacao",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"decision\": \"APPROVE\",\n  \"reason\": \"Documentacao validada\"\n}"
                        },
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests/{{requestId}}/review"
                    }
                },
                {
                    "name": "Recusar Solicitacao",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"decision\": \"REJECT\",\n  \"reason\": \"Endereco inconsistente\"\n}"
                        },
                        "url": "{{msPontoColeta}}/api/pontos-coleta/requests/{{requestIdReject}}/review"
                    }
                }
            ]
        },
        {
            "name": "Base Definitiva",
            "item": [
                {
                    "name": "Listar Aprovados",
                    "request": {
                        "method": "GET",
                        "url": "{{msPontoColeta}}/api/pontos-coleta/approved"
                    }
                }
            ]
        }
    ]
