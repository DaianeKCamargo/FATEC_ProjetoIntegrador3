generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PointCollectionStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

model Noticia {
  id        Int     @id @default(autoincrement())
  titulo    String
  link      String
  imagem    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("noticias")
}

model PointCollection {
  idPc            Int                   @id @default(autoincrement()) @map("id_pc")
  status          PointCollectionStatus @default(PENDENTE)
  nameUser        String                @map("name_user")
  cpfUser         String                @unique @map("cpf_user")
  celUser         String                @map("cel_user")
  emailUser       String                @map("email_user")
  linkPhoto       String                @map("link_photo")
  namePoint       String                @map("name_point")
  cnpjPoint       String                @unique @map("cnpj_point")
  opensDay        String                @map("opens_day")
  hourInit        String                @map("hour_init")
  hourFinal       String                @map("hour_final")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  address         AddressPoint?

  @@index([status])
  @@index([namePoint])
  @@map("point_collections")
}

model AddressPoint {
  idAddress         Int             @id @default(autoincrement()) @map("id_address")
  street            String
  number            String
  complement        String?
  district          String
  city              String
  postCode          String          @map("post_code")
  fkPointCollections Int             @unique @map("fk_point_collections")
  pointCollection    PointCollection @relation(fields: [fkPointCollections], references: [idPc], onDelete: Cascade)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([city])
  @@map("address_point")
}

model AdminUser {
  idAdmin           Int     @id @default(autoincrement()) @map("id_admin")
  username          String  @unique
  passHash          String  @map("pass_hash")
  emailUser         String  @unique @map("email_user")
  resetToken        String? @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("admin_user")
}

model RelatorioAnimais {
  id           Int      @id @default(autoincrement())
  data         DateTime @db.Date
  tipoAnimal   String   @map("tipo_animal")
  quantidade   Int
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("relatorio_animais")
}

model RelatorioTampinhas {
  id            Int      @id @default(autoincrement())
  data          DateTime @db.Date
  quantidadeKg  Float    @map("quantidade_kg")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("relatorio_tampinhas")
}

