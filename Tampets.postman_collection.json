              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Daiane Atualizada\",\n  \"email\": \"daiane.atualizada@email.com\"\n}"
            },
            "url": "{{app}}/api/usuarios/1"
          }
        },
        {
          "name": "Remover Usuario",
          "request": {
            "method": "DELETE",
            "url": "{{app}}/api/usuarios/1"
          }
        }
      ]
    },
