<!DOCTYPE html>
<html>
<head>
    <title><%= relatorio ? "Editar" : "Novo" %> Relatório</title>
</head>
<body>
    <h1><%= relatorio ? "Editar" : "Novo" %> Relatório de Tampinhas</h1>

    <form action="<%= relatorio ? '/tampinhas/' + relatorio.id + '?_method=PUT' : '/tampinhas' %>" method="POST">
        
        <label>Data:</label>
        <input type="date" name="data" value="<%= relatorio ? relatorio.data : '' %>" required>
        <br><br>

        <label>Quantidade (Kg):</label>
        <input type="number" step="0.1" name="quantidadeKg" value="<%= relatorio ? relatorio.quantidadeKg : '' %>" required>
        <br><br>

        <button type="submit">Salvar</button>
    </form>

    <a href="/tampinhas">Voltar</a>
</body>
</html>